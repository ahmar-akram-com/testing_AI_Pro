{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.17.0"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "setup:local": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-local.ps1",
    "start:local": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local.ps1",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "start": "node server.ts",
    "test:qa": "tsx scripts/test-runner.mjs",
    "test:qa:offline": "tsx scripts/test-runner-offline.mjs",
    "postinstall": "node scripts/install-playwright.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sparticuz/chromium": "^148.0.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.50.1",
    "pngjs": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
